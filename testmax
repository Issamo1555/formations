<?php
declare(strict_types=1);

function parseThreeNumbers(string $raw, ?string &$error): ?array
{
    $raw = trim($raw);
    if ($raw === '') {
        $error = "Veuillez entrer exactement 3 nombres.";
        return null;
    }

    // Accepte des espaces multiples, tabs, etc.
    $parts = preg_split('/\s+/', $raw) ?: [];
    if (count($parts) !== 3) {
        $error = "Veuillez entrer exactement 3 nombres.";
        return null;
    }

    foreach ($parts as $p) {
        if (!is_numeric($p)) {
            $error = "Veuillez saisir uniquement des nombres (ex: 10 3.5 -2).";
            return null;
        }
    }

    return [(float)$parts[0], (float)$parts[1], (float)$parts[2]];
}

function computeMax(float $a, float $b, float $c): float
{
    return max($a, $b, $c);
}

$isCli = (PHP_SAPI === 'cli');

if ($isCli) {
    echo "Veuillez entrer 3 nombres séparés par un espace : ";

    $line = fgets(STDIN);
    $line = $line === false ? '' : $line;

    $error = null;
    $nums = parseThreeNumbers($line, $error);
    if ($nums === null) {
        echo $error . "\n";
        exit(1);
    }

    [$a, $b, $c] = $nums;
    $max = computeMax($a, $b, $c);
    echo "Le nombre maximal est : " . $max . "\n";
    exit(0);
}

// Mode navigateur (GET/POST)
$error = null;
$result = null;
$value = '';

if (($_SERVER['REQUEST_METHOD'] ?? 'GET') === 'POST') {
    $value = trim((string)($_POST['nombres'] ?? ''));
    $nums = parseThreeNumbers($value, $error);
    if ($nums !== null) {
        [$a, $b, $c] = $nums;
        $result = computeMax($a, $b, $c);
    }
}

?>
<!doctype html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Maximum de 3 nombres</title>
</head>
<body>
    <h1>Maximum de 3 nombres</h1>

    <form method="post" action="">
        <label>
            Entrez 3 nombres (séparés par des espaces) :
            <input name="nombres" type="text" value="<?= htmlspecialchars($value, ENT_QUOTES, 'UTF-8') ?>" placeholder="Ex: 10 3.5 -2" required>
        </label>
        <button type="submit">Calculer</button>
    </form>

    <?php if ($error !== null): ?>
        <p><?= htmlspecialchars($error, ENT_QUOTES, 'UTF-8') ?></p>
    <?php elseif ($result !== null): ?>
        <p>Le nombre maximal est : <strong><?= htmlspecialchars((string)$result, ENT_QUOTES, 'UTF-8') ?></strong></p>
    <?php endif; ?>
</body>
</html>
